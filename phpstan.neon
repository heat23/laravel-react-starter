includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app
        - routes
        - config

    # Start at level 5 for production-grade projects
    # Levels: 0-9 (0=loosest, 9=strictest)
    level: 5

    # Allow baseline entries that only match in CI (different Larastan version)
    reportUnmatchedIgnoredErrors: false

    # Ignore patterns
    ignoreErrors:
        # Allow dynamic properties on App\Models (Laravel magic)
        - '#Access to an undefined property App\\Models\\[a-zA-Z]+::\$[a-zA-Z]+#'

        # laravel/socialite is in `suggest` — not installed in the base template.
        # Errors disappear once the fork installs socialite.
        - '#(unknown class|invalid type|has invalid type).*Laravel\\Socialite#'
        - '#Laravel\\Socialite\\#'

        # Cashier model dynamic properties — Payment, Invoice, Checkout use PHP magic
        # properties internally; PHPDoc stubs are unavailable at level 5.
        - '#Access to an undefined property Laravel\\Cashier\\(Payment|Invoice|Checkout)::\$#'
        - '#Call to an undefined method Laravel\\Cashier\\(Invoice|Payment|Checkout)::#'

        # Larastan limitation: Collection::map() closure return types are unresolvable
        # when the model uses generic Eloquent base types. Not a real defect.
        - '#contains unresolvable type#'

        # Generic Illuminate\Database\Eloquent\Model dynamic property access — occurs in
        # controllers that operate on relationship collections (e.g. $subscription->items)
        # where Larastan cannot narrow the item type. Fix properly via @return annotations
        # on the relationship methods when touching those controllers.
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::\$#'
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::#'

    # Discover symbols in test files
    scanDirectories:
        - tests

    # Cache for faster subsequent runs
    tmpDir: storage/phpstan
