      { "area": "Accessibility", "audit": 5, "track": "prod-readiness", "score": 8.0, "weight": 0.0167, "finding_count": 2, "summary": "Good foundation with Radix UI, ARIA attributes, focus-visible. Missing skip-to-content link." },
      { "area": "UX Copy", "audit": 6, "track": "prod-readiness", "score": 8.0, "weight": 0.0167, "finding_count": 2, "summary": "Clear error messages, good onboarding copy. Generic billing error messages could be more actionable." },
