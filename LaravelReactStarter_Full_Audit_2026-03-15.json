      { "area": "Architecture & System Design", "audit": 2, "track": "prod-readiness", "score": 9.0, "weight": 0.20, "finding_count": 2, "summary": "Excellent architecture: clean service boundaries, Redis-locked billing, proper middleware stack, feature flags with DB overrides." },
